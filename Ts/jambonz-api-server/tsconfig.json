{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "ES2021.Promise"],
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "moduleResolution": "node"
  },
  "include": [
    "app.ts",
    "lib/**/*.ts",
    "test/**/*.ts",
    "db/**/*.ts",
    "types/**/*.d.ts"
  ]
}
