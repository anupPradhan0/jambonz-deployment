# ============================================================================
# Jambonz Platform Environment Configuration
# ============================================================================
# This file contains all environment variables needed for Jambonz services
# Copy this to .env and customize for your deployment

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
JAMBONES_MYSQL_HOST=localhost
JAMBONES_MYSQL_PORT=3306
JAMBONES_MYSQL_USER=jambones
JAMBONES_MYSQL_PASSWORD=jambones_password
JAMBONES_MYSQL_DATABASE=jambones
JAMBONES_MYSQL_CONNECTION_LIMIT=10

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
JAMBONES_REDIS_HOST=localhost
JAMBONES_REDIS_PORT=6379
JAMBONES_REDIS_PASSWORD=
JAMBONES_REDIS_DB=0

# ============================================================================
# FEATURE SERVER CONFIGURATION
# ============================================================================
FEATURE_SERVER_PORT=3100
FEATURE_SERVER_HOST=0.0.0.0
JAMBONES_LOGLEVEL=info
JAMBONES_SBCS=138.201.59.156
JAMBONES_FREESWITCH=freeswitch:8021:JambonzR0ck$:docker-host

# Drachtio (SIP Server) Configuration
DRACHTIO_HOST=127.0.0.1
DRACHTIO_PORT=9060
DRACHTIO_SECRET=cymru

# ============================================================================
# API SERVER CONFIGURATION
# ============================================================================
API_SERVER_PORT=3000
API_SERVER_HOST=0.0.0.0
JWT_SECRET=your-super-secret-jwt-key-change-this
ENCRYPTION_SECRET=your-encryption-secret-change-this

# Webapp runs in the browser; it must reach the API on the public VPS address.
# Our docker-compose publishes the API on host port 3002.
JAMBONZ_PUBLIC_API_BASE_URL=http://138.201.59.156:3002/v1
JAMBONES_PUBLIC_IP=138.201.59.156
JAMBONES_SBC_PUBLIC_IP=138.201.59.156
JAMBONES_ADVERTISE_IP=138.201.59.156

# ============================================================================
# SBC INBOUND CONFIGURATION
# ============================================================================
SBC_INBOUND_PORT=5060
SBC_INBOUND_HOST=0.0.0.0
SBC_INBOUND_WS_PORT=5061

# ============================================================================
# SBC OUTBOUND CONFIGURATION
# ============================================================================
SBC_OUTBOUND_PORT=5062
SBC_OUTBOUND_HOST=0.0.0.0
SBC_OUTBOUND_WS_PORT=5063

# ============================================================================
# SBC SIP SIDECAR CONFIGURATION
# ============================================================================
SBC_SIP_SIDECAR_PORT=5064
SBC_SIP_SIDECAR_HOST=0.0.0.0

# ============================================================================
# PLIVO SIP TRUNK CONFIGURATION
# ============================================================================
# These will be configured in the Jambonz portal after setup
PLIVO_SIP_SERVER=sip.plivo.com
PLIVO_SIP_PORT=5060
PLIVO_SIP_USERNAME=your-plivo-sip-username
PLIVO_SIP_PASSWORD=your-plivo-sip-password
PLIVO_SIP_DOMAIN=your-plivo-domain.sip.plivo.com

# ============================================================================
# CALL RECORDING CONFIGURATION
# ============================================================================
JAMBONES_CALL_RECORDING_ENABLED=true
JAMBONES_CALL_RECORDING_PATH=/var/recordings

# ============================================================================
# MONITORING AND LOGGING
# ============================================================================
JAMBONES_TIME_SERIES_HOST=localhost
JAMBONES_TIME_SERIES_PORT=9090
ENABLE_METRICS=1
JAMBONES_TRACING_ENABLED=false

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
NODE_ENV=production
HTTP_POOL=1
JAMBONES_HOSTING=1
JAMBONES_TTS_TRIM_SILENCE=1

# ============================================================================
# NETWORK CONFIGURATION
# ============================================================================
JAMBONES_NETWORK_CIDR=10.0.0.0/8
RTP_PORT_MIN=16000
RTP_PORT_MAX=32000

# ============================================================================
# ADVANCED CONFIGURATION
# ============================================================================
# Kubernetes configuration (if deploying on K8s)
K8S=false
K8S_FEATURE_SERVER_SERVICE_NAME=jambonz-feature-server
K8S_FEATURE_SERVER_SERVICE_PORT=3100

# AWS Configuration (if using AWS services)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Azure Configuration (if using Azure services)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=

# Google Cloud Configuration (if using GCP services)
GOOGLE_APPLICATION_CREDENTIALS=
