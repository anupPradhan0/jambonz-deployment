# ============================================================================
# Jambonz Docker deployment .env
# Copy this file to your server and edit secrets before running compose.
# ============================================================================

# Required secrets (CHANGE THESE)
JWT_SECRET=change-me-to-a-long-random-secret
ENCRYPTION_SECRET=change-me-to-a-long-random-secret
JAMBONES_MYSQL_PASSWORD=change-me-to-a-strong-db-password
DRACHTIO_SECRET=change-me-to-a-strong-sip-secret

# Public host/IP used by webapp + SIP advertise
JAMBONZ_PUBLIC_HOST=138.201.59.156
JAMBONZ_PUBLIC_API_BASE_URL=http://138.201.59.156:3002/v1
JAMBONES_PUBLIC_IP=138.201.59.156
JAMBONES_SBC_PUBLIC_IP=138.201.59.156
JAMBONES_ADVERTISE_IP=138.201.59.156
JAMBONES_SBC_ADVERTISED_IP=138.201.59.156

# Optional tuning (defaults in compose are already fine)
JAMBONES_LOGLEVEL=info
JAMBONES_NETWORK_CIDR=10.0.0.0/8
RTP_PORT_MIN=16000
RTP_PORT_MAX=32000
